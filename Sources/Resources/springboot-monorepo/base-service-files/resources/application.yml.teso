server:
  port: {{module.port}}
:
spring:
  data:
    mongodb:
      uri: {{db-uri}}
  webflux:
    cors:
      allowed-origins: "{{allowed-cors-url}}"
      allow-credentials: true
      max-age: 3600
:
spring.graphql.graphiql.enabled : true
spring.graphql.graphiql.path : /graphiql
spring.graphql.path : /graphql
spring.graphql.websocket.path : /subs
