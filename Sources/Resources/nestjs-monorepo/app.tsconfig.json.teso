{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "declaration": false,
    "outDir": "../../dist/apps/{{module_folder_name}}",
    "baseUrl": "./",
    "paths": {
      "libs/*": ["../../libs/*"]
    },
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "test", "**/*spec.ts", "**/*test.ts"]
}
