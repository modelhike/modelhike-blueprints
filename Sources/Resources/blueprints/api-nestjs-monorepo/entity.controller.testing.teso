:
  it('/GET {{entity_name}}/:id existing', async () => {
    const id = existingId; // Mock valid object id
    const obj = { dummy: true }
    const busResponse = InternalResponse.result(obj);
:
    jest.spyOn(queryBus, 'execute').mockResolvedValue(busResponse);
:
    const res = await request(app.getHttpServer())
