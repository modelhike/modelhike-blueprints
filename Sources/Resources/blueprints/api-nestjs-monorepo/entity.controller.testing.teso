import * as request from 'supertest';
import { Test, TestingModule } from '@nestjs/testing';
import { INestApplication, HttpStatus, ExecutionContext, CallHandler } from "@nestjs/common";
import { CommandBus, QueryBus } from '@nestjs/cqrs';
import { CommandOkResponse, QueryOkResponse } from 'libs/includes/external.response';
import { InternalResponse } from 'libs/includes/internal.response';
import { {{entity.name}}Controller } from './controller';
:
const nonExistingId = '000000000000000000000001';
const existingId = '6673bd8c0fcfd8a21bd15300';
const authToken = 'Bearer token'
:
const dataNotFoundError = {
  "appCode": 5000,
  "statusCode": HttpStatus.NOT_FOUND,
  "status": "Failure",
  "error": "Data not found!!"
}
const invalidRequestError = {
  appCode: 4000,
  statusCode: 400,
  status: 'Invalid',
  error: 'Invalid Request!!'
}
:
describe('{{entity.name}}Controller (integration)', () => {
  let app: INestApplication;
  let commandBus: CommandBus;
  let queryBus: QueryBus;
:
