:
  it('/PUT {{entity_name}} non-existing', async () => {
    const payload = {
    "_id": nonExistingId, {{api.entity | sample-json }}
    }
    const busResponse = InternalResponse.noData()
    const response = dataNotFoundError
:
    jest.spyOn(commandBus, 'execute').mockResolvedValue(busResponse);
:
    await request(app.getHttpServer())
      .put('/{{entity_name}}')
      .set('Authorization', authToken)
      .send(payload)
      .expect(HttpStatus.NOT_FOUND)
      .expect(response);
  });

: else if api.is-delete
:
  it('/DELETE {{entity_name}}/:id existing', async () => {
    const id = existingId; // Mock valid object id
    const busResponse = InternalResponse.success()
    const response = { ...CommandOkResponse }
:
    jest.spyOn(commandBus, 'execute').mockResolvedValue(busResponse);
:
    await request(app.getHttpServer())
