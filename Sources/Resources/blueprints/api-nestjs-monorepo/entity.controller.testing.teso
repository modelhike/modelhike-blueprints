      .post('/{{entity_name}}')
      .set('Authorization', authToken)
      .send(payload)
      .expect(HttpStatus.OK)
      .expect(response);
  });
:
  it("POST /{{entity_name}} existing resource", async () => {
    const payload = { {{ api.entity | sample-json }} }
    const busResponse = InternalResponse.success()
    const response = { ...CommandOkResponse }
:
    jest.spyOn(commandBus, 'execute').mockResolvedValue(busResponse);
:
    await request(app.getHttpServer())
      .post("/{{entity_name}}")
      .set('Authorization', authToken)
      .send(payload)
      .expect(HttpStatus.OK)
      .expect(response)
      .then(function () {
          request(app.getHttpServer())
          .post("/{{entity_name}}")
          .set('Authorization', authToken)
          .send(payload)
          .expect(HttpStatus.CONFLICT);
