@startuml
:
skin rose
hide empty methods
hide circle
title {{ module.name }}
:

: for type in module.types
class {{type.name}} {
: for property in type.properties
 {{property.name}}: {{property | typename}}
: end-for
: if type.has-methods
: for method in type.methods
 +{{method.name}}({{method | java-method-params}}) : {{method | java-return-type}}
: end-for
: end-if
}

:

: end-for

:
@enduml
